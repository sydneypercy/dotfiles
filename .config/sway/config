# target                 title     bg    text   indicator  border
client.focused           $pink     $base $text  $mauve     $mauve
client.focused_inactive  $mauve    $base $text  $rosewater $mantle
client.unfocused         $mauve    $base $text  $rosewater $mantle 
client.urgent            $peach    $base $peach $overlay0  $peach
client.placeholder       $overlay0 $base $text  $overlay0  $overlay0
client.background        $base

# Enhancement stuff

for_window [app_id="com.mitchellh.ghostty"] opacity 0.9
for_window [app_id="org.pulseaudio.pavucontrol"] floating true

#Assign apps to workspaces
assign [app_id="waterfox"] $ws2
assign [app_id="spotify"] $ws3
assign [app_id="discord"] $ws4
# assign [class="steam"] $ws10

input type:touchpad {
	tap enabled
	natural_scroll enabled
}

# Enable Tearing
output eDP-1 allow_tearing yes
output * max_render_time off
include pointer
