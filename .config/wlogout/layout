{
    "label" : "lock",
    "action" : "loginctl lock-session",
    "text" : "Lock",
    "keybind" : "l"
}
{
    "label" : "hibernate",
    "action" : "hyprshutdown -t 'Hibernating...' --post-cmd 'systemctl hibernate' ",
    "text" : "Hibernate",
    "keybind" : "h"
}
{
    "label" : "logout",
    "action" : "hyprshutdown  -t 'Logging out ...' --post-cmd 'loginctl kill-session $XDG_SESSION_ID'",
    "text" : "Logout",
    "keybind" : "e"
}
{
    "label" : "shutdown",
    "action" : "hyprshutdown -t 'Shutting down...' --post-cmd 'systemctl poweroff' "
    "text" : "Shutdown",
    "keybind" : "s"
}
{
    "label" : "suspend",
    "action" : "systemctl suspend",
    "text" : "Suspend",
    "keybind" : "u"
}
{
    "label" : "reboot",
    "action" : "hyprshutdown -t 'Rebooting...' --post-cmd 'systemctl reboot' ",
    "text" : "Reboot",
    "keybind" : "r"
}
